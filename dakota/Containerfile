# Dakota live ISO installer image
#
# Build with:
#   just container dakota
#
# Three-stage build:
#   1. dakota-ref   — original Dakota image (provides kernel modules)
#   2. initramfs-builder — Debian: builds a dmsquash-live initramfs against
#                          Dakota's kernel modules in its native glibc environment
#   3. final        — Dakota: receives the rebuilt initramfs + live-env setup
#
# Dakota is GNOME OS / freedesktop-sdk based — no package manager, no dracut.
# The initramfs is built in a separate Debian stage so no cross-distro binary
# grafting is needed; only the initramfs.img output crosses the stage boundary.
# The ISO bootloader is systemd-boot (already in Dakota at
# /usr/lib/systemd/boot/efi/systemd-bootx64.efi) — no GRUB2 or shim required.

# Base image — override to build nvidia or other variants.
# Example: podman build --build-arg BASE_IMAGE=ghcr.io/projectbluefin/dakota-nvidia:latest ...
ARG BASE_IMAGE=ghcr.io/projectbluefin/dakota:latest

# ── Stage 1: Dakota reference (kernel modules source) ────────────────────────
FROM ${BASE_IMAGE} AS dakota-ref

# ── Stage 2: Debian — builds the dmsquash-live initramfs ─────────────────────
# Dracut runs natively in Debian against Dakota's kernel modules.
# Only /tmp/initramfs.img crosses into the final stage.
FROM debian:sid AS initramfs-builder

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        dracut \
        dmsetup \
    && rm -rf /var/lib/apt/lists/*

# Import Dakota's kernel module tree so dracut targets the correct kernel
COPY --from=dakota-ref /usr/lib/modules /usr/lib/modules

# Add Dakota-specific initramfs support for Ventoy/file-backed ISO boot.
COPY src/dracut/95dakota-isofile /usr/lib/dracut/modules.d/95dakota-isofile

RUN set -ex; \
    kernel=$(ls /usr/lib/modules | sort -V | tail -1); \
    echo "Building dmsquash-live initramfs for kernel ${kernel}"; \
    DRACUT_NO_XATTR=1 dracut -v --force --zstd --reproducible --no-hostonly \
        --add "dmsquash-live dakota-isofile" \
        --add-drivers "squashfs overlay loop iso9660 sr_mod cdrom sd_mod usb-storage xhci-pci exfat vfat fat ntfs3 ext4" \
        /tmp/initramfs.img "${kernel}"; \
    ls -lh /tmp/initramfs.img

# ── Stage 3: Final Dakota live image ─────────────────────────────────────────
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# Set to "dev" to pull the tuna-installer dev build (continuous-dev release)
# instead of the stable continuous build.  Useful for testing PRs on the dev
# branch before they land in a stable release.
# Example: just installer_channel=dev iso-sd-boot dakota
ARG INSTALLER_CHANNEL=stable
ENV INSTALLER_CHANNEL=${INSTALLER_CHANNEL}

# DEBUG=1 builds a minimal debug ISO (installer only, SSH enabled).
# Cache-bust: 1778705723
# Declared before the flatpak layer so install-flatpaks.sh can skip Flathub
# apps in debug mode.  Switching debug=0↔1 busts the flatpak cache, but
# debug builds are fast (installer-only) and production builds are cached
# independently.
ARG DEBUG=0
ENV DEBUG=${DEBUG}

# Replace the OCI-mode initramfs with the dmsquash-live initramfs from stage 2
COPY --from=initramfs-builder /tmp/initramfs.img /tmp/initramfs.img
RUN kernel=$(ls /usr/lib/modules | sort -V | tail -1) && \
    mv /tmp/initramfs.img "/usr/lib/modules/${kernel}/initramfs.img" && \
    echo "Replaced initramfs for kernel ${kernel}"

# ── Flatpak install layer ─────────────────────────────────────────────────────
# --mount=type=cache persists /var/lib/flatpak across builds locally.
# Each run reconciles the repo to match src/flatpaks: installs/updates what's
# new, removes what's been dropped.  Only deltas are downloaded on rebuilds.
COPY src/flatpaks /tmp/flatpaks-list
RUN --mount=type=bind,source=src,target=/src \
    --mount=type=cache,target=/var/cache/flatpak-dl,id=dakota-flatpak \
    /src/install-flatpaks.sh

# ── Live-environment configure layer ─────────────────────────────────────────
# COPY all of src/ so any change to config files busts this layer's cache.
COPY src/ /tmp/src/
RUN chmod +x /tmp/src/configure-live.sh && /tmp/src/configure-live.sh

ARG BASE_IMAGE
# Patch installer configs to reference the actual base image for this variant.
# For the default (BASE_IMAGE=ghcr.io/projectbluefin/dakota:latest) this is a no-op.
RUN sed -i "s|ghcr.io/projectbluefin/dakota:latest|${BASE_IMAGE}|g" \
    /etc/bootc-installer/images.json \
    /etc/bootc-installer/recipe.json
